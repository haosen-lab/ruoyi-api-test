# 若依后台管理系统 - API测试环境配置
# 复制此文件为 .env 并根据实际环境修改

# ========== 基础配置 ==========
# 后端API地址
BASE_URL=http://localhost:8080
# 前端地址（可选）
FRONTEND_URL=http://localhost:3000

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=ry

# ========== Redis配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ========== 测试账号 ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 测试用户账号（可选）
TEST_USERNAME=test_user
TEST_PASSWORD=Test@123456

# ========== 其他配置 ==========
# 请求超时时间（秒）
REQUEST_TIMEOUT=30
